<h1><%= @room.name %></h1>

<%= link_to "一覧に戻る", rooms_path %>

<h2>メッセージ一覧</h2>

<% if @messages.any? %>
  <ul>
    <% @messages.each do |message| %>
      <li style="margin-bottom: 12px;">
        <strong><%= message.author_name %></strong><br>
        <%= message.content %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>まだメッセージはありません。</p>
<% end %>

<hr>

<h2>メッセージを送る</h2>

<% if @message.errors.any? %>
  <div>
    <h3><%= @message.errors.count %>件のエラーがあります</h3>
    <ul>
      <% @message.errors.full_messages.each do |error_message| %>
        <li><%= error_message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [@room, @message] do |f| %>
  <div>
    <%= f.label :author_name, "名前" %><br>
    <%= f.text_field :author_name %>
  </div>

  <div style="margin-top: 12px;">
    <%= f.label :content, "メッセージ" %><br>
    <%= f.text_area :content, rows: 4 %>
  </div>

  <div style="margin-top: 12px;">
    <%= f.submit "送信する" %>
  </div>
<% end %>